<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permisos de red para conectar a la impresora vía WiFi/LAN -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Para el servicio en foreground (Android 8+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Para mantener el CPU activo mientras se imprime -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Para leer/escribir imágenes a imprimir desde almacenamiento -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:name=".PrintApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_printer"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_printer"
        android:supportsRtl="true"
        android:theme="@style/Theme.EnduroPrint">

        <!-- ==========================================
             ACTIVITY PRINCIPAL: Configuración
             ========================================== -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ==========================================
             ACTIVITY DE IMPRESIÓN: Recibe el URL scheme
             desde el navegador o apps web.

             Uso desde HTML/JS:
               window.location.href = 'enduroprint://print?type=text&data=Hola+Mundo';
               window.location.href = 'enduroprint://print?type=escpos&data=1B4100...';  (hex)
               window.location.href = 'enduroprint://print?type=html&data=<b>Ticket</b>';

             ========================================== -->
        <activity
            android:name=".PrintActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.EnduroPrint.Transparent">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- URL scheme: enduroprint://print -->
                <data
                    android:scheme="enduroprint"
                    android:host="print" />
            </intent-filter>
        </activity>

        <!-- ==========================================
             SERVICIO EN BACKGROUND
             Mantiene la conexión con la impresora activa.
             Se inicia automáticamente al abrir la app.
             ========================================== -->
        <service
            android:name=".PrinterService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- ==========================================
             RECEIVER: Inicia el servicio al arrancar el dispositivo
             ========================================== -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
