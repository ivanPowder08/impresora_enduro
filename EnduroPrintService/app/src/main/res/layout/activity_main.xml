<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖨 Enduro Print Service"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servicio de impresión LAN para Android"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Estado del servicio -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ESTADO DEL SERVICIO"
            android:textSize="11sp"
            android:textColor="@color/label"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Servicio activo"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detenido"
                    android:textSize="13sp"
                    android:textColor="@color/gray"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/sw_service"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="16dp" />

        <!-- Configuración de red -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONEXIÓN DE RED"
            android:textSize="11sp"
            android:textColor="@color/label"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IP de la impresora"
                android:textSize="13sp"
                android:textColor="@color/label"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_ip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="192.168.1.100"
                android:inputType="text"
                android:textSize="16sp"
                android:background="@color/input_bg"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Puerto (default: 9100)"
                android:textSize="13sp"
                android:textColor="@color/label"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="9100"
                android:inputType="number"
                android:textSize="16sp"
                android:background="@color/input_bg"
                android:padding="10dp" />
        </LinearLayout>

        <!-- Configuración de papel -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPCIONES DE IMPRESIÓN"
            android:textSize="11sp"
            android:textColor="@color/label"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ancho de papel"
                android:textSize="13sp"
                android:textColor="@color/label"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rg_paper_width"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_80mm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80mm (Enduro)"
                    android:layout_marginEnd="24dp"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rb_58mm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="58mm" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Corte automático"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cortar papel al terminar cada ticket"
                        android:textSize="12sp"
                        android:textColor="@color/label" />
                </LinearLayout>

                <Switch
                    android:id="@+id/sw_auto_cut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botones -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="GUARDAR CONFIGURACIÓN"
            android:backgroundTint="@color/primary"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_test_print"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🖨 IMPRIMIR PRUEBA"
            android:backgroundTint="@color/card"
            android:textColor="@color/primary"
            android:layout_marginBottom="24dp" />

        <!-- Instrucciones de uso -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CÓMO USAR DESDE TU APP WEB"
            android:textSize="11sp"
            android:textColor="@color/label"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card"
            android:padding="16dp"
            android:text="En tu HTML/JavaScript:\n\nwindow.location.href =\n  'enduroprint://print?type=text\n   &amp;data=' + encodeURIComponent(ticket);\n\nTipos disponibles:\n• text  — Texto con formato\n• escpos — Comandos ESC/POS hex\n• html  — HTML como imagen\n• image — Imagen Base64"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
